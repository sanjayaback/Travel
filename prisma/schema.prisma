generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  MANAGER
  TICKETING_STAFF
  VISA_OFFICER
  SALES_STAFF
  ACCOUNTANT
  B2B_AGENT
  CUSTOMER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTATION_SENT
  FOLLOW_UP
  CONVERTED
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BookingStatus {
  INQUIRY
  RESERVED
  TICKETED
  CANCELLED
  REFUNDED
  REISSUED
}

enum VisaStatus {
  NEW_APPLICATION
  DOCUMENTS_PENDING
  DOCUMENTS_RECEIVED
  APPOINTMENT_SCHEDULED
  SUBMITTED_TO_EMBASSY
  UNDER_REVIEW
  APPROVED
  REJECTED
  PASSPORT_COLLECTED
  DELIVERED_TO_CUSTOMER
}

enum PackageStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  ESEWA
  KHALTI
  STRIPE
  OTHER
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  BOOKING_DEBIT
  COMMISSION_CREDIT
  REFUND
  ADJUSTMENT
}

enum SupplierType {
  AIRLINE
  HOTEL
  VISA
  TRANSPORT
  TOUR
}

enum DocumentType {
  PASSPORT
  VISA
  TICKET
  HOTEL_VOUCHER
  INVOICE
  RECEIPT
  BANK_STATEMENT
  PHOTO
  OTHER
}

enum NotificationType {
  FOLLOW_UP_DUE
  VISA_APPOINTMENT_REMINDER
  PAYMENT_DUE
  BOOKING_STATUS_UPDATE
  WALLET_RECHARGE_REQUEST
  DOCUMENT_EXPIRY
  NEW_LEAD_ASSIGNED
}

model Agency {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  email          String
  phone          String?
  address        String?
  logoUrl        String?
  defaultCurrency String         @default("NPR")
  users          User[]
  customers      Customer[]
  leads          Lead[]
  flightBookings FlightBooking[]
  visaApplications VisaApplication[]
  tourPackages   TourPackage[]
  packageBookings PackageBooking[]
  quotations     Quotation[]
  invoices       Invoice[]
  payments       Payment[]
  agents         Agent[]
  wallets        Wallet[]
  suppliers      Supplier[]
  documents      Document[]
  communications Communication[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  settings       Setting[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([slug])
}

model Role {
  id          String       @id @default(uuid())
  name        UserRole     @unique
  description String?
  users       User[]
  permissions Permission[] @relation("PermissionRoles")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  roles       Role[]   @relation("PermissionRoles")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String    @id @default(uuid())
  agencyId      String?
  agency        Agency?   @relation(fields: [agencyId], references: [id])
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  phone         String?
  title         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  assignedLeads Lead[]    @relation("AssignedLead")
  flightBookings FlightBooking[] @relation("AssignedFlightStaff")
  visaApplications VisaApplication[] @relation("AssignedVisaOfficer")
  receivedPayments Payment[] @relation("ReceivedBy")
  documents     Document[] @relation("UploadedBy")
  activityLogs  ActivityLog[]
  notifications Notification[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([agencyId])
  @@index([email])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id               String          @id @default(uuid())
  agencyId         String
  agency           Agency          @relation(fields: [agencyId], references: [id])
  name             String
  email            String?
  phone            String
  address          String?
  dateOfBirth      DateTime?
  nationality      String?
  passportNumber   String?
  passportExpiry   DateTime?
  emergencyContact String?
  tags             String[]        @default([])
  notes            String?
  flightBookings   FlightBooking[]
  visaApplications VisaApplication[]
  packageBookings  PackageBooking[]
  quotations       Quotation[]
  invoices         Invoice[]
  payments         Payment[]
  documents        Document[]
  communications   Communication[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  @@index([agencyId, name])
  @@index([agencyId, phone])
}

model Lead {
  id                    String     @id @default(uuid())
  agencyId              String
  agency                Agency     @relation(fields: [agencyId], references: [id])
  assignedStaffId       String?
  assignedStaff         User?      @relation("AssignedLead", fields: [assignedStaffId], references: [id])
  name                  String
  phone                 String
  email                 String?
  source                String?
  interestedDestination String?
  travelDate            DateTime?
  budget                Decimal?   @db.Decimal(12, 2)
  status                LeadStatus @default(NEW)
  priority              Priority   @default(MEDIUM)
  notes                 String?
  nextFollowUpDate      DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  @@index([agencyId, status])
  @@index([agencyId, nextFollowUpDate])
}

model FlightBooking {
  id             String        @id @default(uuid())
  agencyId       String
  agency         Agency        @relation(fields: [agencyId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  supplierId     String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  staffAssignedId String?
  staffAssigned  User?         @relation("AssignedFlightStaff", fields: [staffAssignedId], references: [id])
  airline        String
  flightNumber   String
  departureCity  String
  arrivalCity    String
  departureAt    DateTime
  returnAt       DateTime?
  pnr            String?
  ticketNumber   String?
  passengerDetails Json?
  fareAmount     Decimal       @default(0) @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  serviceCharge  Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  status         BookingStatus @default(INQUIRY)
  paymentStatus  PaymentStatus @default(UNPAID)
  ticketPdfUrl   String?
  invoices       Invoice[]
  documents      Document[]
  communications Communication[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([agencyId, status])
  @@index([agencyId, pnr])
}

model VisaApplication {
  id                 String        @id @default(uuid())
  agencyId           String
  agency             Agency        @relation(fields: [agencyId], references: [id])
  customerId         String
  customer           Customer      @relation(fields: [customerId], references: [id])
  assignedOfficerId  String?
  assignedOfficer    User?         @relation("AssignedVisaOfficer", fields: [assignedOfficerId], references: [id])
  country            String
  visaType           String
  purpose            String?
  applicationDate    DateTime      @default(now())
  appointmentDate    DateTime?
  expectedDecisionDate DateTime?
  passportNumber     String
  status             VisaStatus    @default(NEW_APPLICATION)
  paymentStatus      PaymentStatus @default(UNPAID)
  documentChecklist  Json?
  notes              String?
  invoices           Invoice[]
  documents          Document[]
  communications     Communication[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  @@index([agencyId, status])
  @@index([agencyId, country])
}

model TourPackage {
  id          String          @id @default(uuid())
  agencyId    String
  agency      Agency          @relation(fields: [agencyId], references: [id])
  title       String
  destination String
  duration    String
  startDate   DateTime?
  endDate     DateTime?
  price       Decimal         @default(0) @db.Decimal(12, 2)
  inclusions  String?
  exclusions  String?
  itinerary   Json?
  hotels      String?
  transport   String?
  meals       String?
  images      String[]        @default([])
  availability Int            @default(0)
  status      PackageStatus   @default(DRAFT)
  bookings    PackageBooking[]
  quotations  Quotation[]
  documents   Document[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([agencyId, destination])
  @@index([agencyId, status])
}

model PackageBooking {
  id            String        @id @default(uuid())
  agencyId      String
  agency        Agency        @relation(fields: [agencyId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  tourPackageId String
  tourPackage   TourPackage   @relation(fields: [tourPackageId], references: [id])
  seats         Int           @default(1)
  totalAmount   Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(UNPAID)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Quotation {
  id            String          @id @default(uuid())
  agencyId      String
  agency        Agency          @relation(fields: [agencyId], references: [id])
  customerId    String?
  customer      Customer?       @relation(fields: [customerId], references: [id])
  tourPackageId String?
  tourPackage   TourPackage?    @relation(fields: [tourPackageId], references: [id])
  quoteNumber   String
  title         String
  type          String
  items         Json
  tax           Decimal         @default(0) @db.Decimal(12, 2)
  serviceCharge Decimal         @default(0) @db.Decimal(12, 2)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  total         Decimal         @default(0) @db.Decimal(12, 2)
  validUntil    DateTime?
  status        QuotationStatus @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@unique([agencyId, quoteNumber])
  @@index([agencyId, status])
}

model Invoice {
  id                 String          @id @default(uuid())
  agencyId           String
  agency             Agency          @relation(fields: [agencyId], references: [id])
  customerId         String?
  customer           Customer?       @relation(fields: [customerId], references: [id])
  flightBookingId    String?
  flightBooking      FlightBooking?  @relation(fields: [flightBookingId], references: [id])
  visaApplicationId  String?
  visaApplication    VisaApplication? @relation(fields: [visaApplicationId], references: [id])
  invoiceNumber      String
  tax                Decimal         @default(0) @db.Decimal(12, 2)
  discount           Decimal         @default(0) @db.Decimal(12, 2)
  total              Decimal         @default(0) @db.Decimal(12, 2)
  paidAmount         Decimal         @default(0) @db.Decimal(12, 2)
  dueAmount          Decimal         @default(0) @db.Decimal(12, 2)
  paymentStatus      PaymentStatus   @default(UNPAID)
  dueDate            DateTime?
  items              InvoiceItem[]
  payments           Payment[]
  documents          Document[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  @@unique([agencyId, invoiceNumber])
  @@index([agencyId, paymentStatus])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id            String        @id @default(uuid())
  agencyId      String
  agency        Agency        @relation(fields: [agencyId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  invoiceId     String?
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod @default(CASH)
  transactionId String?
  paymentDate   DateTime      @default(now())
  receivedById  String?
  receivedBy    User?         @relation("ReceivedBy", fields: [receivedById], references: [id])
  notes         String?
  receiptFile   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([agencyId, method])
  @@index([agencyId, paymentDate])
}

model Agent {
  id             String    @id @default(uuid())
  agencyId       String
  agency         Agency    @relation(fields: [agencyId], references: [id])
  userId         String?   @unique
  companyName    String
  contactPerson  String
  email          String
  phone          String
  address        String?
  commissionRate Decimal   @default(0) @db.Decimal(5, 2)
  creditLimit    Decimal   @default(0) @db.Decimal(12, 2)
  isApproved     Boolean   @default(false)
  wallet         Wallet?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([agencyId, companyName])
}

model Wallet {
  id           String              @id @default(uuid())
  agencyId     String
  agency       Agency              @relation(fields: [agencyId], references: [id])
  agentId      String              @unique
  agent        Agent               @relation(fields: [agentId], references: [id])
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  creditLimit  Decimal             @default(0) @db.Decimal(12, 2)
  transactions WalletTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id])
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(12, 2)
  reference   String?
  status      String                @default("Pending")
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([walletId, type])
}

model Supplier {
  id             String          @id @default(uuid())
  agencyId       String
  agency         Agency          @relation(fields: [agencyId], references: [id])
  type           SupplierType
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  openingBalance Decimal         @default(0) @db.Decimal(12, 2)
  notes          String?
  flightBookings FlightBooking[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([agencyId, type])
  @@index([agencyId, name])
}

model Document {
  id                String           @id @default(uuid())
  agencyId          String
  agency            Agency           @relation(fields: [agencyId], references: [id])
  customerId        String?
  customer          Customer?        @relation(fields: [customerId], references: [id])
  flightBookingId   String?
  flightBooking     FlightBooking?   @relation(fields: [flightBookingId], references: [id])
  visaApplicationId String?
  visaApplication   VisaApplication? @relation(fields: [visaApplicationId], references: [id])
  tourPackageId     String?
  tourPackage       TourPackage?     @relation(fields: [tourPackageId], references: [id])
  invoiceId         String?
  invoice           Invoice?         @relation(fields: [invoiceId], references: [id])
  uploadedById      String?
  uploadedBy        User?            @relation("UploadedBy", fields: [uploadedById], references: [id])
  type              DocumentType
  title             String
  fileUrl           String
  mimeType          String?
  size              Int?
  expiryDate        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@index([agencyId, type])
  @@index([agencyId, title])
}

model Communication {
  id                String           @id @default(uuid())
  agencyId          String
  agency            Agency           @relation(fields: [agencyId], references: [id])
  customerId        String?
  customer          Customer?        @relation(fields: [customerId], references: [id])
  flightBookingId   String?
  flightBooking     FlightBooking?   @relation(fields: [flightBookingId], references: [id])
  visaApplicationId String?
  visaApplication   VisaApplication? @relation(fields: [visaApplicationId], references: [id])
  channel           String
  template          String?
  subject           String?
  message           String
  status            String           @default("Draft")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([agencyId, channel])
}

model Notification {
  id        String           @id @default(uuid())
  agencyId  String
  agency    Agency           @relation(fields: [agencyId], references: [id])
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([agencyId, isRead])
}

model ActivityLog {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([agencyId, entity])
  @@index([agencyId, createdAt])
}

model Setting {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, key])
}
